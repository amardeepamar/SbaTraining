
@{
    ViewBag.Title = "Update Employee Training";
    ViewBag.Heading = "Training";
}

<script src="~/Content/assets/js/jquery.min.js"></script>
<script type="text/javascript">
    $(document).ready(function () {

        $('#DesignationId').on("change", function () {
            $('#Employee_infoId').attr('disabled', false);
            var id =@Model.DesignationId
            id = $(this).val();
            $('#Employee_infoId').empty();
            $('#Employee_infoId').append('<Option>-- select Employee information list --</Option>');
             $.ajax({
                 url: '/Employee/BindDesignation/' + id,
                 success: function (result) {
                     $.each(result, function (i, data) {
                         $('#Employee_infoId').append('<Option value=' + data.id + ' >' + data.name + '</Option>');
                     });
                 }
             });
        });
    });

</script>

<div class="row">
    @Html.Partial("~/Views/Shared/_Breadcrumb.cshtml")
    <div class="col-xl-10 mx-auto">
        <div class="card">
            <div class="card-body p-4">
                <div class="row">
                    <div class="card-header col-md-6">
                        <div class="text-md-start">
                            <button type="submit" class="btn btn-primary" onclick="window.location.href='/employee/EmpTrainingList'">Employee Training List</button>
                        </div>
                    </div>
                    <div class="card-header col-md-6">
                        @Html.Partial("~/Views/Shared/MessageForm.cshtml")
                    </div>
                    <div class="card-header">
                        @using (Html.BeginForm("UpdateEmpTraining", "Employee", FormMethod.Post))
                        {
                            @Html.Partial("~/Views/Employee/Partial/_Training.cshtml")
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

