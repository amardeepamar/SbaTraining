@model List<DTO.EmployeeInfo_EmployeeTrainingVM>
@{
    ViewBag.Title = "GetTrainingInfo";
}
<script src="~/Content/DeleteRecord.js"></script>
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">
                    Complete SBA Training Details
                </h4>                
                @if (Model != null && Model.Any())
                {
                    <table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
                        <thead>
                            <tr>
                                <th>District</th>
                                <th>Block</th>
                                <th>Facility</th>
                                <th>Employee Designation</th>
                                <th>Employee Name</th>
                                <th>Mobile</th>

                                <th>Training Period</th>
                                <th>Batch</th>
                                <th>Training Designation</th>
                                <th>EmployeeNameOfTraining</th>
                                <th>Employee From-To Date Training</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr id="State_Health_Training_@item.Emp_Id">
                                    <td>@item.District</td>
                                    <td>@item.Block</td>
                                    <td>@item.Facility</td>
                                    <td>@item.Employee_Designation</td>
                                    <td>@item.EmployeeName</td>
                                    <td>@item.Mobile</td>

                                    <td id="State_Health_Employee_@item.Tra_Id">@item.Training_MonthYearName</td>
                                    <td>@item.Batch</td>
                                    <td>@item.Traning_Designation</td>
                                    <td>@item.EmployeeNameOfTraining</td>
                                    <td>@item.From_Date.ToString("dd MMM yyyy") - @item.To_Date.ToString("dd MMM yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>No training data found.</p>
                }
            </div>
        </div>
    </div>
    <!-- end col -->
</div>
@Html.Partial("~/Views/Shared/ModalMessage.cshtml")




