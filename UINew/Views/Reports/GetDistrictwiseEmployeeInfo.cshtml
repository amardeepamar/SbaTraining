@using DTO
@model IEnumerable<DAL.Employee_info>
@{
    ViewBag.Title = "Get district wise employee training";
    ViewBag.Heading = "Reports";
    SessionDTO session = (SessionDTO)Session["UserInfo"];
    // int i = 1;
}
<style type="text/css">
    .readyonly {
        background-color: #efefef !important;
    }
</style>
<script type="text/javascript">
        $(document).ready(function () {
            $('#searchForm').on('submit', function (e) {
                e.preventDefault(); // Prevent the default form submission

                $.ajax({
                    url: '@Url.Action("GetDistrictwiseEmployeeInfo", "Reports")',
                    type: 'POST',
                    data: $(this).serialize(), // Serialize form data
                    success: function (result) {
                        $('#datatable-buttons').html(result); // Load the partial view into the div
                    },
                    error: function () {
                        alert('Error occurred while fetching data.');
                    }
                });
            });
        });
</script>


<div class="row">
    @Html.Partial("~/Views/Shared/_Breadcrumb.cshtml")
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body p-4">
                <div class="row p-3">
                    <label class="h5">Download</label>
                    <div class="col-3">
                        

                        <!-- After search, display the download button -->
                        @if (ViewBag.Districts != null)
                        {
                            <button id="downloadExcelBtn" class="btn btn-success" onclick="downloadExcel()"><i class="fa fa-2x fa-file-excel"></i></button>
                        }

                        <script>
                            function downloadExcel() {
                                var searchDistrict = document.getElementById("searchDistrict").value;
                                window.location.href = '/Reports/ExportToExcel?searchDistrict=' + encodeURIComponent(searchDistrict);
                            }
                        </script>

                        @*<button class="btn btn-success" onclick="window.location.href='@Url.Action("DistrictExcel", "Reports", new { searchDistrict = ViewBag.SelectedDistrict})'"><i class="fa fa-2x fa-file-excel"></i></button>*@
                        <button class="btn btn-danger" onclick="window.location.href='@Url.Action("DistrictPDF", "Reports", new { searchDistrict = ViewBag.SelectedDistrict })'"><i class="fa fa-2x fa-file-pdf"></i></button>
                    </div>
                </div>
                <div class="row">
                    <div class="card-header">
                        @using (Html.BeginForm("GetDistrictwiseEmployeeInfo", "Reports", FormMethod.Post, new { id = "searchForm" }))
                        {
                            <div class="row p-3">
                                <div class="col-xl-2"> @Html.Label("Search by District")</div>
                                @if (session.Role == "1" || session.Role == "2")
                                {
                                    <div class="col-xl-8">@Html.DropDownList("searchDistrict", (SelectList)ViewBag.Districts, "All", new { @class = "form-control", @readonly = "readonly" })</div>
                                }
                                else
                                {
                                    <div class="col-xl-8">@Html.DropDownList("searchDistrict", (SelectList)ViewBag.Districts, new { @class = "form-control readyonly", @readonly = "readonly" })</div>
                                }
                                <div class="col-xl-2"><button type="submit" class="btn btn-primary datatable-buttons">Search</button></div>
                            </div>
                        }
                        <hr />

                        <!-- Placeholder for Data Table -->
                        <table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;"></table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

