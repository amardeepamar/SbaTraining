@model IEnumerable<DAL.Employee_info>

@{
    ViewBag.Title = "Get district-block-wise employee information";
    ViewBag.Heading = "Reports";
}
<style type="text/css">
    .readyonly {
        background-color: #efefef !important;
    }
</style>

<script type="text/javascript">
        $(document).ready(function () {
            $('#searchForm').on('submit', function (e) {
                e.preventDefault(); // Prevent the default form submission

                $.ajax({
                    url: '@Url.Action("GetDistrictBlockEmployeeInfo", "Reports")',
                    type: 'POST',
                    data: $(this).serialize(), // Serialize form data
                    success: function (result) {
                        $('#productTable').html(result); // Load the partial view into the div
                    },
                    error: function () {
                        alert('Error occurred while fetching data.');
                    }
                });
            });
        });
</script>
@using DTO
@{ 
    SessionDTO session = (SessionDTO)Session["UserInfo"];
}
<div class="row">
    @Html.Partial("~/Views/Shared/_Breadcrumb.cshtml")
    <div class="col-xl-12">
        <div class="card">
            <div class="card-body p-4">
                <div class="row p-3">
                    <label class="h5">Download</label>
                    <div class="col-3">
                        <button class="btn btn-success" onclick="window.location.href='@Url.Action("ExportToExcel", new { searchDistrict = ViewBag.SelectedDistrict, searchBlock = ViewBag.SelectedBlock })'"><i class="fa fa-2x fa-file-excel"></i></button>
                        <button class="btn btn-danger" onclick="window.location.href='@Url.Action("ExportToPDF", new { searchDistrict = ViewBag.SelectedDistrict, searchBlock = ViewBag.SelectedBlock })'"><i class="fa fa-2x fa-file-pdf"></i></button>
                    </div>
                </div>
                <div class="row">
                    <div class="card-header">
                        @using (Html.BeginForm("GetDistrictBlockEmployeeInfo", "Reports", FormMethod.Post, new { id = "searchForm" }))
                        {
                            <div class="row p-3">
                                <div class="col-xl-3"> @Html.Label("Search by District and Block")</div>
                                @if (session.Role == "1" || session.Role == "2")
                                {
                                    <div class="col-xl-4">@Html.DropDownList("searchDistrict", (SelectList)ViewBag.Districts, "All", new { @class = "form-control", id = "districtDropdown" })</div>
                                }
                                else
                                {
                                    <div class="col-xl-4">@Html.DropDownList("searchDistrict", (SelectList)ViewBag.Districts, new { @class = "form-control readyonly", id = "districtDropdown" })</div>
                                }
                                <div class="col-xl-4">@Html.DropDownList("searchBlock", (SelectList)ViewBag.Blocks, "All", new { @class = "form-control", id = "blockDropdown" })</div>
                                <div class="col-xl-1"><button type="submit" class="btn btn-default datatable-buttons"><i class="fa fa-2x fa-search"></i></button></div>
                            </div>
                        }
                        <hr />



                        <!-- Placeholder for Data Table -->
                        <div id="productTable"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



