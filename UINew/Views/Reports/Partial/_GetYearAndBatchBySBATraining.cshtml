


@{
    int i = 1;
}
@model IEnumerable<DAL.Employee_Training>
@if (Model != null && Model.Any())
{
    <table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
        <thead>
            <tr>
                <th>SNo</th>
                <th>Designation</th>
                <th>Employee Name</th>
                <th>Entry Date</th>
                <th>From Date</th>
                <th>To Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr id="shs_@item.TrainingId">
                    <td>@(i++)</td>
                    <td>@item.DesignationMaster1.DesignationEn</td>
                    <td>@item.Employee_info.Name</td>
                    <td>@item.AddDate.ToString("MM/dd/yyyy")</td>
                    <td>
                        @if (item.FromDate.HasValue)
                        {
                            @item.FromDate.Value.ToString("MM/dd/yyyy")
                        }
                        else
                        {
                            @:N/A
                        }
                    </td>
                    <td>
                        @if (item.ToDate.HasValue)
                        {
                            @item.ToDate.Value.ToString("MM/dd/yyyy")
                        }
                        else
                        {
                            @:N/A
                        }
                    </td>
                    @*<td>@Html.DisplayFor(modelItem => item.FromDate, "NullableDateTime")</td>
                        <td>@Html.DisplayFor(modelItem => item.ToDate, "NullableDateTime")</td>*@
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="text-center text-bg-dark p-lg-4 h4">Sba training not found for the selected Batch for this year.</div>
}

