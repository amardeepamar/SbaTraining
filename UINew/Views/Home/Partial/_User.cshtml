@model DTO.LoginMasterDTO

<div class="row g-3">
    <input type="number" hidden value="@Model.UserId" name="UserId" />
    <div class="col-md-6">
        <label for="Username" class="form-label">Username</label>
        @Html.TextBoxFor(x => x.Username, new { @class = "form-control", @placeholder = "Username" })
        @Html.ValidationMessageFor(x => x.Username)
    </div>
    <div class="col-md-6">
        <label for="Password" class="form-label">Password</label>
        <div class="input-group" id="show_hide_password">
            @Html.TextBoxFor(x => x.Password, new { @class = "form-control", @type = "password", @placeholder = "Password" })
            <a href="javascript:;" class="input-group-text bg-transparent"><i class="bx bx-hide"></i></a>
        </div>
        @Html.ValidationMessageFor(x => x.Password)
    </div>
    <div class="col-md-6">
        <label for="Password" class="form-label">Retype Password</label>
        <div class="input-group" id="show_hide_password2">
            @Html.TextBoxFor(x => x.ConfirmPassword, new { @class = "form-control", @type = "password", @placeholder = "Retype Password" })
            <a href="javascript:;" class="input-group-text bg-transparent"><i class="bx bx-hide"></i></a>
        </div>
        @Html.ValidationMessageFor(x => x.ConfirmPassword)
    </div>


    <div class="col-md-6">
        <label for="ContactNo" class="form-label">Contact Number</label>
        @Html.TextBoxFor(x => x.ContactNo, new { @class = "form-control", @placeholder = "Contact Number", @required = "required", title = "Please enter exactly 10 digits", maxlength = "10" })
        @Html.ValidationMessageFor(x => x.ContactNo)
    </div>
    <div class="col-md-6">
        <label for="Email" class="form-label">Email</label>
        @Html.TextBoxFor(x => x.Email, new { @class = "form-control", @placeholder = "Email" })
        @Html.ValidationMessageFor(x => x.Email)
    </div>
    <div class="col-md-6">
        <label for="Email" class="form-label">Full Name</label>
        @Html.TextBoxFor(x => x.SurName, new { @class = "form-control", @placeholder = "Full Name" })
        @Html.ValidationMessageFor(x => x.SurName)
    </div>

    <div class="col-md-6">
        <lable>Role Type</lable>
        @Html.DropDownList("RoleId", Model.RoleType, "Select Role type", new { @class = "form-control" })
        @Html.HiddenFor(m => m.RoleName, new { @class = "form-control" })
        @Html.ValidationMessageFor(x => x.RoleId)
    </div>
    <div class="col-md-6">
        @Html.LabelFor(x => x.UserImage)
        <br />
        <input type="file" name="UserImage" accept="image/gif, image/jpeg,image/png, image/jpg" onchange="$('#UserImage')[0].src = window.URL.createObjectURL(this.files[0])" />
        <br />
        @if (Model != null && Model.Imagepath != null)
        {
            <br />
            <img src="~/Content/UserImage/@Model.Imagepath" width="300" height="200" /> }
        else
        {
            <img src="" width="300" height="200" id="UserImage" />}
        @Html.ValidationMessageFor(x => x.Imagepath)
    </div>
    <div class="col-md-6">
        <div class="d-md-flex d-grid align-items-center gap-3">
            <button type="submit" class="btn btn-primary px-4">Submit</button>
            <a href="/home/userlist" class="btn btn-light px-4">Back to list</a>
        </div>
    </div>
</div>
<!--Password show & hide js -->
<script>
    $(document).ready(function () {
        $("#show_hide_password a").on('click', function (event) {
            event.preventDefault();
            if ($('#show_hide_password input').attr("type") == "text") {
                $('#show_hide_password input').attr('type', 'password');
                $('#show_hide_password i').addClass("bx-hide");
                $('#show_hide_password i').removeClass("bx-show");
            } else if ($('#show_hide_password input').attr("type") == "password") {
                $('#show_hide_password input').attr('type', 'text');
                $('#show_hide_password i').removeClass("bx-hide");
                $('#show_hide_password i').addClass("bx-show");
            }
        });


        $("#show_hide_password2 a").on('click', function (event) {
            event.preventDefault();
            if ($('#show_hide_password2 input').attr("type") == "text") {
                $('#show_hide_password2 input').attr('type', 'password');
                $('#show_hide_password2 i').addClass("bx-hide");
                $('#show_hide_password2 i').removeClass("bx-show");
            } else if ($('#show_hide_password2 input').attr("type") == "password") {
                $('#show_hide_password2 input').attr('type', 'text');
                $('#show_hide_password2 i').removeClass("bx-hide");
                $('#show_hide_password2 i').addClass("bx-show");
            }
        });
    });
</script>
<!--app JS-->
