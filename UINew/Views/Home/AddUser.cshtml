
@{
    ViewBag.Title = "Add User";
    ViewBag.Heading = "Users";
}

<div class="row">
    @Html.Partial("~/Views/Shared/_Breadcrumb.cshtml")
    <div class="col-xl-10 mx-auto">
        <div class="card">
            <div class="card-body p-4">
                <div class="row">
                    <div class="card-header col-md-6">
                        <div class="text-md-start">
                            <button type="submit" class="btn btn-primary" onclick="window.location.href='/home/UserList'">Registered User List</button>
                        </div>
                    </div>
                    <div class="card-header col-md-6">
                        @Html.Partial("~/Views/Shared/MessageForm.cshtml")
                    </div>
                    <div class="card-header">
                        @using (Html.BeginForm("AddUser", "Home", FormMethod.Post, new { @enctype = "multipart/form-data" }))
                        {
                            @Html.Partial("~/Views/Home/Partial/_User.cshtml")
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
