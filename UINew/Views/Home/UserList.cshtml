@model List<DTO.LoginMasterDTO>
@{
    ViewBag.Title = "User List";
    int i = 1;
}

<script src="~/Content/DeleteRecord.js"></script>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">
                    Sba User List
                    @{
                        if (User.IsInRole("Superadmin") || User.IsInRole("Admin"))
                        {
                            <a style="padding-left: 751px;" href="/home/adduser">Add User</a>
                        }
                    }
                </h4>
                <table id="datatable-buttons" class="table table-striped table-bordered dt-responsive nowrap" style="border-collapse: collapse; border-spacing: 0; width: 100%;">
                    <thead>
                        <tr>
                            @if (User.Identity.IsAuthenticated)
                            {
                                if (User.IsInRole("Superadmin") || User.IsInRole("Admin"))
                                {
                                    <th>#</th>
                                }
                            }
                            <th>SNo</th>
                            <th>Username</th>
                            @*<th>Password</th>*@
                            <th>Name</th>
                            <th>Role</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="Shs_@item.UserId">
                                @if (User.Identity.IsAuthenticated)
                                {
                                    if (User.IsInRole("Superadmin") || User.IsInRole("Admin"))
                                    {
                                        <td>
                                            <a href="/Home/UpdateUser/@item.UserId" class="pe-2">
                                                <img src="~/Content/icons/edit.png" height="20" width="20" />
                                            </a>

                                            <a href="#" data-bs-toggle="modal" data-bs-target="#modalmessage">
                                                <img src="~/Content/icons/delete-16.ico" onclick="AskQuestion('/Home/DeleteUser/',@item.UserId)" />
                                            </a>


                                        </td>
                                    }
                                }
                                <td> @(i++)</td>
                                <td>@item.Username</td>
                                @*<td>
                                     @Html.Raw(new string('*', item.Password.Length))
                                </td>*@
                                <td>@item.SurName</td>
                                <td>@item.RoleName</td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        </div>
    </div>
    <!-- end col -->
</div>
<!-- end row -->
@Html.Partial("~/Views/Shared/ModalMessage.cshtml")


