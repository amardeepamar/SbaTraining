    <script src="~/Content/libs/datatables.net-bs4/js/dataTables.bootstrap4.min.js"></script>
    <!-- Buttons examples -->
    <script src="~/Content/libs/datatables.net-buttons/js/dataTables.buttons.min.js"></script>
    <script src="~/Content/libs/datatables.net-buttons-bs4/js/buttons.bootstrap4.min.js"></script>
    <script src="~/Content/libs/jszip/jszip.min.js"></script>
    <script src="~/Content/libs/pdfmake/build/pdfmake.min.js"></script>
    <script src="~/Content/libs/pdfmake/build/vfs_fonts.js"></script>
    <script src="~/Content/libs/datatables.net-buttons/js/buttons.html5.min.js"></script>
    <script src="~/Content/libs/datatables.net-buttons/js/buttons.print.min.js"></script>
    <script src="~/Content/libs/datatables.net-buttons/js/buttons.colVis.min.js"></script>
    <!-- Responsive examples -->
    <script src="~/Content/libs/datatables.net-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/Content/libs/datatables.net-responsive-bs4/js/responsive.bootstrap4.min.js"></script>
    <!-- Datatable init js -->
    <script src="~/Content/js/pages/datatables.init.js"></script>
    <script src="~/Content/js/app.js"></script>
    <style>
        #example2_wrapper label {
            display: contents !important;
        }

            #example2_wrapper label input {
                Margin-left: 5px !important;
            }
    </style>
    <script>
        $(document).ready(function () {
            var table = $('#example2').DataTable({
                lengthChange: false,
                buttons: ['copy', 'excel', 'pdf', 'print']
            });

            table.buttons().container()
                .appendTo('#example2_wrapper .col-md-6:eq(0)');
        });
    </script>
</body>
</html>
