@model List<ElectionPlanner.Models.DTO.ActivitiesDTO>

@using ElectionPlanner.Models.DTO
@{
    ViewBag.Title = "Manage Activities";
    SessionDTO session = (SessionDTO)Session["UserInfo"];
}



<div class="card">
    <div class="card-body p-4">
        <h5 class="card-title">Manage Activities</h5>
        <hr />
        <div class="form-body mt-4">
            <div class="row">
                <div class="col-lg-12">
                    <div class="border border-3 p-4 rounded">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-control py-2  mb-5">
                                    <div class="row">
                                        <div class="col-6">
                                            <label class="h6">District:</label>
                                            <select id="DistId" name="DistId" class="form-control">
                                                <option value="">-- Select District --</option>
                                                @foreach (var district in ViewBag.Districts)
                                                {
                                                    if (session.DistId == district.DistId)
                                                    {
                                                        <option value="@district.DistId">@district.DistNameEn</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="col-6">
                                            <label class="h6">Ac:</label>
                                            <select id="AcId" name="AcId" class="form-control">
                                                <option value="">-- Select Ac --</option>
                                            </select>
                                        </div>
                                    </div>

                                </div>
                                <div class="table-responsive">
                                    <h5 class="card-title">PollDay Sublayer Lists</h5>
                                    <hr />
                                    <!-- #region DataGrid of PollDay Sublayer Lists -->
                                    <table id="example" class="table table-striped table-bordered">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>PollDay SubLayer NameEn</th>
                                                <th>Starting Day</th>
                                                <th>Ending Day</th>
                                                <th>Duration</th>
                                                <th>Tentative Starting Date</th>
                                                <th>Tentative Ending Date</th>
                                                <th>Remark Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{ string str1 = ""; }
                                            @foreach (var act in Model)
                                            {
                                                if (str1 != act.PollDayNameEn)
                                                {
                                                    str1 = act.PollDayNameEn;

                                                    <tr>
                                                        <th colspan="9" class="border" style="font-weight:bolder">@act.PollDayNameEn</th>
                                                    </tr>
                                                }
                                                <tr>
                                                    <td>@act.Id</td>
                                                    <td>@act.PollDaySubLayerNameEn</td>
                                                    <td>@act.StartingDay</td>
                                                    <td>@act.EndingDay</td>
                                                    <td>@act.Duration</td>
                                                    <td>@act.TentativeStartingDate.ToString("MMM dd, yyyy")</td>
                                                    <td>@act.TentativeEndingDate.ToString("MMM dd, yyyy")</td>

                                                    <td>
                                                        @if (DateTime.Now >= act.TentativeStartingDate && (DateTime.Now <= act.TentativeEndingDate || DateTime.Now > act.TentativeEndingDate))
                                                        {
                                                            <select class="form-control remark-dropdown">
                                                                <option value="-11">Select Status</option>

                                                                @foreach (var pollday in ViewBag.remarks as List<ElectionPlanner.Models.DTO.RemarksDTO>)
                                                                {
                                                                    <option value="@pollday.Id">@pollday.RemarkName</option>

                                                                }
                                                            </select>
                                                        }
                                                        else
                                                        {
                                                            <span>N/A</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (DateTime.Now >= act.TentativeStartingDate && (DateTime.Now <= act.TentativeEndingDate || DateTime.Now > act.TentativeEndingDate))
                                                        {
                                                            <button type="button" class="btn btn-sm btn-warning save-btn"
                                                                    data-id="@act.Id">
                                                                Save
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <th>#</th>
                                                @*<th>PollDay NameEn</th>*@
                                                <th>PollDay SubLayer NameEn</th>
                                                <th>Starting Day</th>
                                                <th>Ending Day</th>
                                                <th>Duration</th>
                                                <th>Tentative Starting Date</th>
                                                <th>Tentative Ending Date</th>
                                                <th>Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                    <!-- #endregion -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--end row-->
        </div>
    </div>
</div>


