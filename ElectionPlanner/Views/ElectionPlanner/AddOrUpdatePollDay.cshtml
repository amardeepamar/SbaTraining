@model List<ElectionPlanner.Models.DTO.PollDayDTO>
@{
    ViewBag.Title = "Manage PollDay";
}

<div class="card">
    <div class="card-body p-4">
        <h5 class="card-title">Manage PollDay</h5>
        <hr />
        <div class="form-body mt-4">
            <div class="row">
                <div class="col-lg-4">
                    <div class="border border-3 p-4 rounded">
                        <div class="row">
                            <h5 class="card-title">Add PollDay</h5>
                            <hr />  
                            <!-- Add/Update Form -->
                            <form id="polldayForm" method="post" action="@Url.Action("AddOrUpdatePollDay", "ElectionPlanner")">
                                <input type="hidden" id="Id" name="Id" value="0" />
                                <div class="col-12">
                                    <div class="form-group pb-2">
                                        <label class="h6">PollDay Name:</label>
                                        <input type="text" id="PollDayNameEN" name="PollDayNameEN" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary">Save</button>
                                    </div>
                                </div>
                            </form>

                        </div>
                    </div>
                </div>

                <div class="col-lg-8">
                    <div class="border border-3 p-4 rounded">
                        <div class="card">
                            <div class="card-body">
                                <div class="table-responsive">
                                    <h5 class="card-title">PollDay Lists</h5>
                                    <hr />
                                    <table id="example2" class="table table-striped table-bordered">
                                        <thead>
                                            <tr>
                                                <th>PollDay Name</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var pollday in ViewBag.pollday as List<ElectionPlanner.Models.DTO.PollDayDTO>)
                                            {
                                                <tr id="ceo_@pollday.Id">
                                                    <td>@pollday.PollDayNameEN</td>
                                                    <td>
                                                        <button type="button" class="btn btn-sm btn-warning" onclick="editPollDay(@pollday.Id, '@pollday.PollDayNameEN')">Update</button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <th>PollDay Name</th>
                                                <th>Actions</th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!--end row-->
        </div>
    </div>
</div>



<script>
    // Populate form for editing
    function editPollDay(polldayId, polldayName) {
        document.getElementById("Id").value = polldayId;
        document.getElementById("PollDayNameEN").value = polldayName;
    }
</script>

