@model List<ElectionPlanner.Models.DTO.ActivitiesDTO>

@using ElectionPlanner.Models.DTO
@{
    ViewBag.Title = "Manage Activities";
    SessionDTO session = (SessionDTO)Session["UserInfo"];
}



<div class="card">
    <div class="card-body p-4">
        <h5 class="card-title">Manage Activities</h5>
        <hr />
        <div class="form-body mt-4">
            <div class="row">

                <div class="col-lg-12">
                    <div class="border border-3 p-4 rounded">
                        <div class="card">
                            <div class="card-body">
                                <div class="form-control py-2  mb-5">
                                    <div class="row">
                                        @*<label><span>District Session </span>@session.DistId</label>
                                            <label><span>Ac Session </span>@session.AcId</label>*@

                                        <div class="col-6">
                                            <label class="h6">District:</label>
                                            <select id="DistId" name="DistId" class="form-control">
                                                <option value="">-- Select District --</option>
                                                @foreach (var district in ViewBag.Districts)
                                                {

                                                    if (session.DistId == district.DistId)
                                                    {
                                                        <option value="@district.DistId">@district.DistNameEn</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="col-6">
                                            <label class="h6">Ac:</label>
                                            <select id="AcId" name="AcId" class="form-control">
                                                <option value="">-- Select Ac --</option>
                                            </select>
                                        </div>


                                        @*@{
                                                // Retrieve session values as strings.
                                                var sessionDistId = session.DistId.ToString() != null ? session.DistId.ToString() : "";
                                                var sessionAcId = session.AcId.ToString() != null ? session.AcId.ToString() : "";
                                            }
                                            <label>District Session Value: @session.DistId</label>
                                            <label>Ac Session Value: @session.AcId</label>

                                            <div class="col-6">
                                                <label class="h6">District:</label>
                                                <select id="DistId" name="DistId" class="form-control">
                                                    <option value="">-- Select District --</option>
                                                    @foreach (var district in ViewBag.Districts as List<ElectionPlanner.Models.DTO.Ddl.GetAllDistrictDTO>)
                                                    {
                                                        // Compare the district's ID with the session value and mark selected if they match.
                                                        var isSelected = district.DistId.ToString() == sessionDistId ? "selected" : "";
                                                        <option value="@district.DistId" @Html.Raw(isSelected)>@district.DistNameEn</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-6">
                                                <label class="h6">Ac:</label>
                                                <select id="AcId" name="AcId" class="form-control">
                                                    <option value="">-- Select Ac --</option>
                                                </select>
                                            </div>*@

                                    </div>

                                    <!-- #region Featching [dbo].[tblActivities] -->

                                    <div id="Ac_click_Show" style="display:none;">
                                        <div class="row">
                                            <div class="col-2 mt-3">
                                                <label class="h6">Remark:</label>
                                                <span id="activityRemark"></span>
                                            </div>
                                            <div class="col-3 mt-3">
                                                <label class="h6">Remark Name:</label>
                                                <span id="RemarkName"></span>
                                            </div>
                                            <div class="col-2 mt-3">
                                                <label class="h6">District:</label>
                                                <span id="District"></span>
                                            </div>
                                            <div class="col-3 mt-3">
                                                <label class="h6">District Name:</label>
                                                <span id="DistrictNameEn"></span>
                                            </div>
                                            <div class="col-2 mt-3">
                                                <label class="h6">Ac:</label>
                                                <span id="Ac"></span>
                                            </div>
                                            <div class="col-3 mt-3">
                                                <label class="h6">Ac Name:</label>
                                                <span id="AC_NAME_EN"></span>
                                            </div>
                                            <div class="col-2 mt-3">
                                                <label class="h6">PDSL:</label>
                                                <span id="tblPollDaySubLayerMasterId"></span>
                                            </div>
                                            <div class="col-7 mt-3">
                                                <label class="h6">PollDay SubLayer Name:</label>
                                                <span id="PollDaySubLayerNameEn"></span>
                                            </div>
                                            <div class="col-2 mt-3">
                                                <label class="h6">User Code:</label>
                                                <span id="UserCode"></span>
                                            </div>
                                            <div class="col-3 mt-3">
                                                <label class="h6">Username:</label>
                                                <span id="Username"></span>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- #endregion -->
                                </div>
                                <div class="table-responsive">
                                    <h5 class="card-title">PollDay Sublayer Lists</h5>
                                    <hr />
                                    <!-- #region DataGrid of PollDay Sublayer Lists -->
                                    <table id="example" class="table table-striped table-bordered">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                @*<th>PollDay NameEn</th>*@
                                                <th>PollDay SubLayer NameEn</th>
                                                <th>Starting Day</th>
                                                <th>Ending Day</th>
                                                <th>Duration</th>
                                                <th>Tentative Starting Date</th>
                                                <th>Tentative Ending Date</th>
                                                <th>Remark Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{ string str1 = ""; }
                                            @foreach (var act in Model)
                                            {
                                                if (str1 != act.PollDayNameEn)
                                                {
                                                    str1 = act.PollDayNameEn;

                                                    <tr>
                                                        <th colspan="9" class="border" style="font-weight:bolder">@act.PollDayNameEn</th>
                                                    </tr>
                                                }
                                                <tr>
                                                    <td>@act.Id</td>
                                                    @*<td>@act.PollDayNameEn</td>*@
                                                    <td>@act.PollDaySubLayerNameEn</td>
                                                    <td>@act.StartingDay</td>
                                                    <td>@act.EndingDay</td>
                                                    <td>@act.Duration</td>
                                                    <td>@act.TentativeStartingDate.ToString("MMM dd, yyyy")</td>
                                                    <td>@act.TentativeEndingDate.ToString("MMM dd, yyyy")</td>
                                                    
                                                    <td>
                                                        @if (DateTime.Now >= act.TentativeStartingDate && (DateTime.Now <= act.TentativeEndingDate || DateTime.Now > act.TentativeEndingDate))
                                                        {
                                                            <select class="form-control remark-dropdown">
                                                                <option value="-11">Select Status</option>

                                                                @foreach (var pollday in ViewBag.remarks as List<ElectionPlanner.Models.DTO.RemarksDTO>)
                                                                {
                                                                    <option value="@pollday.Id">@pollday.RemarkName</option>

                                                                }
                                                            </select>
                                                        }
                                                        else
                                                        {
                                                            <span>N/A</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (DateTime.Now >= act.TentativeStartingDate && (DateTime.Now <= act.TentativeEndingDate || DateTime.Now > act.TentativeEndingDate))
                                                        {
                                                            <button type="button" class="btn btn-sm btn-warning save-btn"
                                                                    data-id="@act.Id">
                                                                Save
                                                            </button>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <th>#</th>
                                                @*<th>PollDay NameEn</th>*@
                                                <th>PollDay SubLayer NameEn</th>
                                                <th>Starting Day</th>
                                                <th>Ending Day</th>
                                                <th>Duration</th>
                                                <th>Tentative Starting Date</th>
                                                <th>Tentative Ending Date</th>
                                                <th>Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                    <!-- #endregion -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--end row-->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        // Function to toggle the visibility of Ac_click_Show
        function showAcClickShow() {
            var acClickShow = document.getElementById('Ac_click_Show');
            acClickShow.style.display = 'block'; // Show the div when a dropdown is selected
        }
        document.getElementById('AcId').addEventListener('change', function () {
            if (this.value) { // Check if a valid option is selected
                showAcClickShow();
            }
        });

        $('.remark-dropdown').attr('disabled', true);
        $('.save-btn').attr('disabled', true);
        $("#DistId").change(function () {
            $('.remark-dropdown').attr('disabled', false);
            $('.save-btn').attr('disabled', false);
        var districtId = $(this).val();
        $("#AcId").html('<option value="">Loading...</option>');
        var acIdFromSession = '@session.AcId';  // Access session.AcId from Razor
        if (districtId) {
            $.ajax({
                url: '@Url.Action("GetAcByDistrict", "ElectionPlanner")',
                type: 'GET',
                data: { distId: districtId },
                success: function (response) {
                    $("#AcId").html('<option value="">-- Select Ac --</option>');
                    $.each(response, function (index, ac) {
                        var selected = (ac.AcId == acIdFromSession) ? 'selected' : '';  // Set selected if it matches session.AcId
                        $("#AcId").append('<option value="' + ac.AcId + '" ' + selected + '>' + ac.AcNameEn + '</option>');
                    });
                },
                error: function () {
                    alert("Failed to load AC data.");
                    $("#AcId").html('<option value="">-- Select Ac --</option>');
                }
            });
        } else {
            $("#AcId").html('<option value="">-- Select Ac --</option>');
        }
     });
        $(".save-btn").click(function () {
            var button = $(this);
            var remarkId = button.closest("tr").find(".remark-dropdown").val();
            var tblPollDaySubLayerMasterId = button.data("id");
            var DistrictId = $("#DistId").val();
            var AcId = $("#AcId").val();
            //alert(DistrictId);
            //alert(AcId);
            if (remarkId == "-11") {
                alert("Please select a remark.");
                return;
            }
            var activity = {
                Id: tblPollDaySubLayerMasterId, // This is tblPollDaySubLayerMasterId
                Remark: remarkId,
                District: DistrictId,
                Ac: AcId
            };
            $.ajax({
                 url: '@Url.Action("AddOrUpdateActivities", "ElectionPlanner")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(activity),
                success: function (response) {
                    if (response.success) {
                        alert("Activity saved successfully!");
                        } else {
                        alert("Error saving activity.");
                        }
                    },
                    error: function () {
                        alert("An error occurred while saving.");
                        }
             });
        });



      // When AC dropdown changes
     $("#AcId").change(function () {
         var acId = $(this).val();
         var districtId = $("#DistId").val();
         if (districtId && acId)
         {
             $.ajax({
              url: '@Url.Action("GetActivityDetailsByAc", "ElectionPlanner")',
              type: "GET",
              data: { district: districtId, ac: acId },
              success: function (response) {
                  if (response) {
                      $("#tblPollDaySubLayerMasterId").text(response.tblPollDaySubLayerMasterId);
                      $("#PollDaySubLayerNameEn").text(response.PollDaySubLayerNameEn);
                      $("#activityRemark").text(response.Remark);
                      $("#RemarkName").text(response.RemarkName);
                      $("#District").text(response.District);
                      $("#DistrictNameEn").text(response.DistrictNameEn);
                      $("#Ac").text(response.Ac);
                      $("#AC_NAME_EN").text(response.AC_NAME_EN);
                      $("#UserCode").text(response.UserId);
                      $("#Username").text(response.Username)
                  }
                  else {
                      $("#tblPollDaySubLayerMasterId").text("No record found");
                      $("#PollDaySubLayerNameEn").text("No record found");
                      $("#activityRemark").text("No record found.");
                      $("#RemarkName").text("No record found");
                      $("#District").text("No record found");
                      $("#DistrictNameEn").text("No record found");
                      $("#Ac").text("No record found");
                      $("#AC_NAME_EN").text("No record found");
                      $("#UserId").text("No record found");
                      $("#Username").text("No record found");
                  }
              },
              error: function () {
                  alert("No records found.");
              }
             });
         } else {
          $("#tblPollDaySubLayerMasterId").text("");
          $("#PollDaySubLayerNameEn").text("");
          $("#activityRemark").text("");
          $("#RemarkName").text("");
          $("#District").text("");
          $("#DistrictNameEn").text("");
          $("#Ac").text("");
          $("#AC_NAME_EN").text("");
          $("#UserCode").text("");
          $("#Username").text("")
     }
 });



    });
</script>









