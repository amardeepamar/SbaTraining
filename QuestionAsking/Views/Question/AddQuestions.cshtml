
@{
    ViewBag.Title = "Add Questions";
}


<div class="row">
    <div class="col-xl-8">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Question Ask</h4>
                <form id="myForm" method="post" post="/Question/AddQuestions" class="needs-validation" novalidate>
                    <label class="form-label">Are you working in a private company?</label>
                            <div>
                                <div class="row">
                                    <div class="col-1">
                                        <div class="form-check mb-3">
                                            <input class="form-check-input" type="radio" name="formRadios"
                                                   id="formRadios1">
                                            <label class="form-check-label" for="formRadios1">
                                                Yes
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-1">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="formRadios"
                                                   id="formRadios2" checked>
                                            <label class="form-check-label" for="formRadios2">
                                                No
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>

                    <div id="companyDetails">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Name</label>
                                    <input type="text" class="form-control" name="Name" placeholder="Enter Name">
                                </div>
                            </div>
                            <!-- end col -->
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Designation</label>
                                    <select class="form-control" name="DesignationId">
                                        <option value="">-- Select Designation --</option>
                                        @if (ViewBag.Designations != null)
                                        {
                                            foreach (var item in ViewBag.Designations)
                                            {
                                                <option value="@item.DesignationId">@item.DesignationName</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Mobile</label>
                                    <input type="text" class="form-control" name="Mobile" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Question</label> 
                                    <select class="form-control" name="DesignationId">
                                        <option value="">-- Select Question --</option>
                                        @if (ViewBag.Questions != null)
                                        {
                                            foreach (var item in ViewBag.Questions)
                                            {
                                                <option value="@item.QuestionId">@item.QuestionText</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                            <!-- end col -->
                        </div>
                        <!-- end row -->
                        
                        <button class="btn btn-primary" type="submit">Submit form</button>
                    </div>
                </form>
                <!-- end form -->
            </div>
        </div>
        <!-- end card -->
    </div> <!-- end col -->
    <!-- end col -->
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const radioYes = document.getElementById('formRadios1');
        const radioNo = document.getElementById('formRadios2');
        const companyDetails = document.getElementById('companyDetails');

        // Initially hide the form fields if "No" is selected
        if (radioNo.checked) {
            companyDetails.style.display = 'none';
        }

        // Add event listeners to toggle visibility based on radio button selection
        radioYes.addEventListener('change', function () {
            companyDetails.style.display = 'block';
        });

        radioNo.addEventListener('change', function () {
            companyDetails.style.display = 'none';
        });
    });
</script>
